layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
    pane split_direction="Vertical" {
        // Slim docked rail. A small percent (not a fixed cell count) keeps it
        // resizable — zellij won't resize fixed-size panes — so Super b (a
        // MessagePlugin "flock-toggle-width") can expand it in place, leaving the
        // content panes' arrangement intact. The plugin drives it to fixed column
        // targets (slim ~5, expanded ~40).
        pane size="5%" borderless=true {
            plugin location="zellij:flock-sidebar"
        }
        pane
    }
    pane size=2 borderless=true {
        plugin location="status-bar"
    }
}
