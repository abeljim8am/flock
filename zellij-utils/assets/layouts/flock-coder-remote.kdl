// Durable runtime for a Coder workspace. The tracker uses the normal Flock
// detection/hook machinery but suppresses its pane; the host gateway renders
// the unified local/cloud sidebar from its versioned snapshots.
layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
    pane split_direction="Vertical" {
        pane size=1 borderless=true {
            plugin location="zellij:flock-sidebar" {
                tracker_only "true"
                coder_enabled "true"
            }
        }
        pane
    }
    pane size=2 borderless=true {
        plugin location="status-bar"
    }
}

on_force_close "detach"
session_serialization true
